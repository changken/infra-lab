# VPC Configuration
vpc_cidr = "192.168.0.0/16"

# Availability Zones
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c", "us-east-1d"]

# Public Subnets (one CIDR per AZ, same order as availability_zones)
public_subnet_cidrs = ["192.168.1.0/24", "192.168.3.0/24", "192.168.5.0/24", "192.168.7.0/24"]

# Private Subnets (one CIDR per AZ, same order as availability_zones)
private_subnet_cidrs = ["192.168.2.0/24", "192.168.4.0/24", "192.168.6.0/24", "192.168.8.0/24"]

# VPC Options
enable_dns_hostnames = true
enable_dns_support   = true

# Security / Access Control
personal_pc_cidr = "100.0.0.1/32"
