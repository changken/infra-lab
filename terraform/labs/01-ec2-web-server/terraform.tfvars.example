# Terraform Variables Configuration
# Copy this file to terraform.tfvars and customize values:
#   cp terraform.tfvars.example terraform.tfvars

#--------------------------------------------------------------
# General Settings
#--------------------------------------------------------------
environment = "dev"
project     = "terraform-web-server"

#--------------------------------------------------------------
# EC2 Settings
#--------------------------------------------------------------
instance_type    = "t3.micro"
root_volume_size = 20

#--------------------------------------------------------------
# Network Settings
#--------------------------------------------------------------
availability_zone = "us-east-1a"
allowed_ssh_cidr  = "YOUR_IP_ADDRESS/32" # Replace with your IP

#--------------------------------------------------------------
# SSH Key Settings
#--------------------------------------------------------------
key_name = "my-ec2-key"
