# 複製此檔案為 terraform.tfvars 並填入實際值
# cp terraform.tfvars.example terraform.tfvars

# ⚠️ Hetzner Cloud API Token
# 從 https://console.hetzner.cloud > 專案 > Security > API Tokens > Generate API Token 取得
# 權限選 Read & Write
hcloud_token = "YOUR_HCLOUD_TOKEN_HERE"

project     = "hetzner-linux"
environment = "dev"

# 你的公網 IP（執行 curl ifconfig.me 取得，後面加 /32）
my_ip = "1.2.3.4/32"

# SSH 公鑰內容（執行 cat ~/.ssh/id_rsa.pub 取得）
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2E..."

# 位置：sin=新加坡、fsn1=德國 Falkenstein、nbg1=德國 Nuremberg、hel1=芬蘭、ash=美國
# 完整列表：https://docs.hetzner.com/cloud/general/locations/
location = "sin"

# 規格：cx22=2vCPU/4GB ~€3.79/月（最便宜）
# 完整列表：https://www.hetzner.com/cloud/
server_type = "cx22"

# 映像：ubuntu-24.04、ubuntu-22.04、debian-12、fedora-41
image = "ubuntu-24.04"

server_name = "hetzner-dev"
backups     = false
