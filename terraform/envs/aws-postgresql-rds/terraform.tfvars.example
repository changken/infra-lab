region      = "us-east-1"
project     = "pgsql-rds"
environment = "dev"

# RDS
instance_class    = "db.t3.micro"
allocated_storage = 20
engine_version    = "16"

# 資料庫認證
db_name     = "labdb"
db_username = "pgadmin"
db_password = "YourStrongPassword123!"  # 改成你自己的密碼

# 網路（必須填入你的 IP，不可用 0.0.0.0/0）
allowed_cidr        = "1.2.3.4/32"  # ⚠️  改成你的實際 IP（curl ifconfig.me）
publicly_accessible = true           # 從外部連線才需要 true
