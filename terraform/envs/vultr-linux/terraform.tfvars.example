# 複製此檔案為 terraform.tfvars 並填入實際值
# cp terraform.tfvars.example terraform.tfvars

# ⚠️ Vultr API Key（從 https://my.vultr.com/settings/#settingsapi 取得）
api_key = "YOUR_VULTR_API_KEY"

project     = "vultr-linux"
environment = "dev"

# 你的公網 IP（執行 curl ifconfig.me 取得）
my_ip = "1.2.3.4/32"

# SSH 公鑰內容（執行 cat ~/.ssh/id_rsa.pub 取得）
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2E..."

# 區域：nrt=東京、sgp=新加坡、lax=洛杉磯、ewr=紐澤西
# 完整列表：https://www.vultr.com/api/#operation/list-regions
region = "nrt"

# 規格：vc2-1c-1gb ~$6/月（最便宜 Cloud Compute）
# 完整列表：https://www.vultr.com/api/#tag/plans
plan = "vc2-1c-1gb"

# OS ID：1743 = Ubuntu 22.04 LTS x64
# 完整列表：https://www.vultr.com/api/#operation/list-os
os_id = 1743

hostname    = "vultr-dev"
enable_ipv6 = false
backups     = "disabled"
