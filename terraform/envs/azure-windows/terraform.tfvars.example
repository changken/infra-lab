# 複製此檔案為 terraform.tfvars 並填入實際值
# cp terraform.tfvars.example terraform.tfvars

# Azure Subscription ID（執行 az account show --query id -o tsv 取得）
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

location    = "japaneast"
project     = "az-win-bastion"
environment = "dev"

# 你的公網 IP（執行 curl ifconfig.me 取得）
my_ip = "1.2.3.4/32"

# 網路設定（使用預設值即可，與 aws-linux 10.20/aws-windows 10.30 不衝突）
vnet_cidr       = "10.50.0.0/16"
public_subnets  = { "public-1" = "10.50.1.0/24" }
private_subnets = { "private-1" = "10.50.11.0/24" }

# 費用：Standard_B2s ~$0.0416/hr（練完當天請 terraform destroy）
vm_size         = "Standard_B2s"
os_disk_size_gb = 128

# RDP 密碼（不填則自動生成 20 字元強密碼，存至本地 .txt 檔）
# admin_password = "MyP@ssw0rd123!"

# WinRM HTTPS (5986) 遠端 PowerShell 管理（預設關閉）
enable_winrm = false

timezone = "Tokyo Standard Time"
