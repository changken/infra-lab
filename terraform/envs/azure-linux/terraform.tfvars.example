# 複製此檔案為 terraform.tfvars 並填入實際值
# cp terraform.tfvars.example terraform.tfvars

# Azure Subscription ID（執行 az account show --query id -o tsv 取得）
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

location    = "japaneast"
project     = "az-linux-bastion"
environment = "dev"

# 你的公網 IP（執行 curl ifconfig.me 取得）
my_ip = "1.2.3.4/32"

# 網路設定（使用預設值即可，與 aws-linux 10.20/aws-windows 10.30 不衝突）
vnet_cidr       = "10.40.0.0/16"
public_subnets  = { "public-1" = "10.40.1.0/24" }
private_subnets = { "private-1" = "10.40.11.0/24" }

# 費用：Standard_B1s ~$0.0104/hr（首年 750hr/月 免費額度）
vm_size         = "Standard_B1s"
os_disk_size_gb = 30

# SSH 公鑰（不填則自動生成，私鑰存至本地 .pem 檔）
# admin_ssh_public_key = "ssh-rsa AAAA..."
