# Example Terraform Variables
# Copy this file to terraform.tfvars and fill in your actual values
# terraform.tfvars is ignored by git for security

# ============================================================================
# AWS Variables
# ============================================================================

# AWS region
aws_region = "us-east-1"

# AWS EC2 instance type for control plane (t3.medium = 2 vCPU, 4 GB RAM)
cp_instance_type = "t3.medium"

# AWS EC2 instance type for worker nodes (t3.small = 1 vCPU, 2 GB RAM, cheaper)
worker_instance_type = "t3.small"

# Number of worker nodes (default: 2)
# worker_count = 2

# AWS SSH public key (repo-local; for emergency access only)
# Generate with: ssh-keygen -t ed25519 -f ./.ssh/aws_emergency_ed25519 -N ""
aws_ssh_public_key_path = "./.ssh/aws_emergency_ed25519.pub"

# AWS availability zone (optional, leave empty for auto-select)
# aws_availability_zone = "us-east-1a"

# ============================================================================
# Pre-apply: create SSM parameters manually (not managed by Terraform)
# ============================================================================
#
# aws ssm put-parameter \
#   --name "/k3s-lab/tailscale-auth-key" \
#   --value "tskey-auth-REPLACE_ME" \
#   --type SecureString \
#   --region us-east-1
